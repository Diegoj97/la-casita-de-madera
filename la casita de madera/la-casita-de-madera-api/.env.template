# Server
PORT=3000
NODE_ENV=development

# PostgreSQL (local Docker or Neon)
# Option A: individual vars (local)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=la_casita_de_madera
DB_USERNAME=postgres
DB_PASSWORD=your_password_here

# Option B: connection string (Render/Neon)
# DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

DB_SSL=false

# Cloudinary (required for production image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Auth
JWT_SECRET=your_jwt_secret_here
ADMIN_USER=admin
ADMIN_PASS=your_admin_password_here

# CORS (comma-separated origins, e.g. Netlify URL)
ALLOWED_ORIGINS=http://localhost:4200
